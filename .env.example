OPENAI_URL=https://neolink.com/api/v1
OPENAI_API_KEY=replace-with-your-key
OPENAI_MODEL=gpt-4o-mini

# Optional
APP_URL=http://localhost:3000
APP_TIME_ZONE=Asia/Shanghai
ARXIV_LIMIT=100
OPENAI_CONCURRENCY=3
CRON_SECRET=replace-with-a-random-secret
ARXIV_STORE_BACKEND=file
ARXIV_DATA_FILE_NAME=arxiv-state.json
MAX_STORED_PAPERS=800

# Vercel Blob storage, recommended for Vercel deployments.
# Create and connect a private Blob store in Vercel, then set:
# ARXIV_STORE_BACKEND=blob
# ARXIV_BLOB_STATE_PATH=arxiv/arxiv-state.json
# ARXIV_BLOB_ACCESS=private
# BLOB_READ_WRITE_TOKEN=vercel-injects-this-when-the-store-is-connected
