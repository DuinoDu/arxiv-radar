# --- AI analysis (OpenAI-compatible) ---
OPENAI_URL=openai-url
OPENAI_API_KEY=replace-with-your-key
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/arxiv_radar

# --- Conductor SSO login ---
# Register this app in Conductor's CONDUCTOR_SSO_CLIENTS_JSON with the exact
# callback URL `${APP_URL}/api/auth/callback`. The exchanged user token stays
# inside the encrypted HttpOnly session cookie.
CONDUCTOR_BASE_URL=https://conductor-ai.top
CONDUCTOR_SSO_CLIENT_ID=arxiv-radar
CONDUCTOR_SSO_CLIENT_SECRET=replace-with-the-registered-client-secret
APP_URL=http://localhost:3000
# Used to encrypt arxiv-radar's own HttpOnly session cookie.
# Generate with: openssl rand -base64 32
ARXIV_AUTH_SECRET=replace-with-a-random-secret

# Per-user settings — the arxiv fetch URL & daily schedule, and the Conductor
# daemon host / workspace / app name / backend / chat token — are configured
# in the in-app settings popup after login and stored per user in PostgreSQL.
# They are NOT environment variables.

# --- Optional ---
APP_TIME_ZONE=Asia/Shanghai
DATABASE_POOL_MAX=10
ARXIV_LIMIT=100
ARXIV_WORKER_POLL_MS=300000
OPENAI_CONCURRENCY=3
CRON_SECRET=replace-with-a-random-secret
MAX_STORED_PAPERS=800
# Used by one-off tag backfill scripts: node scripts/backfill-*-tag.mjs
ARXIV_USER_ID=replace-with-conductor-user-id
