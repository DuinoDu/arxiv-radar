OPENAI_URL=https://neolink.com/api/v1
OPENAI_API_KEY=replace-with-your-key
OPENAI_MODEL=gpt-4o-mini

# --- Conductor App SDK (chat backend) ---
# Required to power the per-paper chat. The token is held by the BFF only;
# the browser never sees it.
# TODO(account-system): when the app gains user accounts these will move
# into the user profile / settings page; env vars stay as the local-dev fallback.
CONDUCTOR_BASE_URL=https://conductor.example.com
CONDUCTOR_TOKEN=replace-with-your-token
CONDUCTOR_DAEMON_HOST=replace-with-your-daemon-host
CONDUCTOR_WORKSPACE_PATH=replace-with-an-absolute-path-on-the-daemon-host
CONDUCTOR_APP_NAME=arxiv-radar
# Backend CLI used to run the chat AI. Must match a key in the daemon's
# `~/.conductor/config.yaml::allow_cli_list`. Leave empty for the daemon
# default. Example values: `codex`, `claude`, `codex-fast`.
CONDUCTOR_BACKEND_TYPE=

# --- Conductor SSO login ---
# Register this app in Conductor's CONDUCTOR_SSO_CLIENTS_JSON with the exact
# callback URL `${APP_URL}/api/auth/callback`.
CONDUCTOR_SSO_CLIENT_ID=arxiv-radar
CONDUCTOR_SSO_CLIENT_SECRET=replace-with-the-registered-client-secret
# Used to encrypt arxiv-radar's own HttpOnly session cookie.
# Generate with: openssl rand -base64 32
ARXIV_AUTH_SECRET=replace-with-a-random-secret

# Optional
APP_URL=http://localhost:3000
APP_TIME_ZONE=Asia/Shanghai
ARXIV_LIMIT=100
OPENAI_CONCURRENCY=3
CRON_SECRET=replace-with-a-random-secret
ARXIV_STORE_BACKEND=file
ARXIV_DATA_FILE_NAME=arxiv-state.json
MAX_STORED_PAPERS=800

# Vercel Blob storage, recommended for Vercel deployments.
# Create and connect a private Blob store in Vercel, then set:
# ARXIV_STORE_BACKEND=blob
# ARXIV_BLOB_STATE_PATH=arxiv/arxiv-state.json
# ARXIV_BLOB_ACCESS=private
# BLOB_READ_WRITE_TOKEN=vercel-injects-this-when-the-store-is-connected
